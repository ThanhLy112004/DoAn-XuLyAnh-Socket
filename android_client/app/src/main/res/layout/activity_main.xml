<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtUserId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập User ID"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtIpServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập IP Server (vd: 192.168.1.10)"
            android:inputType="text" />

        <RadioGroup
            android:id="@+id/rgProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rbTcp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="TCP" />
            <RadioButton android:id="@+id/rbUdp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UDP" />
        </RadioGroup>

        <Spinner
            android:id="@+id/spinnerCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">
            <Button android:id="@+id/btnCapture" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Chụp ảnh" />
            <Button android:id="@+id/btnGallery" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Gallery" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:enabled="false"
            android:text="Gửi lên Server" />

        <!-- BẢNG GIÁM SÁT MẠNG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F0F0F0"
            android:orientation="vertical"
            android:padding="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIÁM SÁT TRUYỀN TẢI"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvSentStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gửi: 0/0 gói - 0 KB/s"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvReceivedStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhận: 0/0 gói - 0 KB/s"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng thời gian: 0 ms"
                android:textColor="#FF0000"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Trạng thái: Sẵn sàng" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kết quả từ Server:" android:textStyle="bold" />
        <ImageView
            android:id="@+id/imgResult"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="4dp"
            android:background="#EEEEEE"
            android:scaleType="centerInside" />

    </LinearLayout>
</ScrollView>